# Context for a bespoke claude devops tool.
.dev-context

# VS Code settings (we dynamically change these between worktrees, so we don't want to commit them)
.vscode/

# Python bytecode
__pycache__/
*.pyc
*.pyo
# Packaging artifacts
*.egg-info/
*.egg
dist/
build/
.eggs/
# Virtual environments
.venv/
# Linter and test caches
.ruff_cache/
.pytest_cache/
.mypy_cache/

# Editor swap files
.*.swp
